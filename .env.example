# Snyk (required for live API calls)
SNYK_TOKEN=
SNYK_ORG_ID=
# Default Snyk registry integration ID (used when a per-registry ID below is not set).
# Integration UUIDs are per org — use the IDs from the new org when you change SNYK_ORG_ID.
SNYK_INTEGRATION_ID=

# Azure (required unless you only use --images-file)
# Comma-separated subscription IDs to discover AKS clusters in.
AZURE_SUBSCRIPTION_ID=
# Optional: limit discovery to one resource group
# AZURE_RESOURCE_GROUP=

# Optional: route imports to the correct Snyk integration for each registry host.
# If unset, SNYK_INTEGRATION_ID is used (often wrong for multi-registry clusters).
# SNYK_INTEGRATION_ID_ACR=          # *.azurecr.io
# SNYK_INTEGRATION_ID_GCP=         # Google Artifact Registry (*-docker.pkg.dev) and GCR (*.gcr.io, gcr.io/)
# SNYK_INTEGRATION_ID_MCR=         # mcr.microsoft.com
# SNYK_INTEGRATION_ID_DOCKER_HUB=  # docker.io / implicit Docker Hub (e.g. redis:alpine)
# SNYK_INTEGRATION_ID_ECR=         # *.amazonaws.com / ECR
#
# Image refs come from AKS pods (or --images-file). The ACR integration must match your
# registry host (e.g. myregistry.azurecr.io).

# Optional: default https://api.snyk.io and https://snyk.io for REST vs v1 import
# SNYK_REST_BASE=https://api.snyk.io
# SNYK_V1_BASE=https://snyk.io
# SNYK_REST_VERSION=2024-10-15
