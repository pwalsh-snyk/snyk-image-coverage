# Fill in the variables below, then:
#   pip install -r requirements.txt && python reconcile.py
# Azure: az login (or AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID for a service principal).
# After you add secrets, keep this file local — do not commit or push it.

# Required (Snyk)
SNYK_TOKEN=
SNYK_ORG_ID=
SNYK_INTEGRATION_ID=

# Required for AKS discovery (skip if you only use --images-file)
AZURE_SUBSCRIPTION_ID=

# Optional
# AZURE_RESOURCE_GROUP=
# SNYK_INTEGRATION_ID_ACR=
# SNYK_INTEGRATION_ID_GCP=
# SNYK_INTEGRATION_ID_MCR=
# SNYK_INTEGRATION_ID_DOCKER_HUB=
# SNYK_INTEGRATION_ID_ECR=
# SNYK_REST_BASE=https://api.snyk.io
# SNYK_V1_BASE=https://snyk.io
# SNYK_REST_VERSION=2024-10-15
# SNYK_TAG_IMPORTED_PROJECTS=1
# SNYK_IMPORT_TAG_KEY=image
# SNYK_IMPORT_TAG_VALUE=deployed
